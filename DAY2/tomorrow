# 🧱 PART 2 — INSTALL PROXY (FROM TARBALL)

## 1. Pull from GitHub

cd /opt
git clone <your repo>
cd ollama-proxy-bundle

---

## 2. Extract tarball

tar -xzvf ollama_gunicorn.tar.gz

---

## 3. Install dependencies (OFFLINE)

pip3 install --no-index --find-links=requirements flask requests gunicorn

---

## 4. Verify install

python3 -c "import flask, requests"

---

# 🧱 PART 3 — CONFIGURE PROXY

## 1. Edit proxy

nano ollama_proxy.py

---

## 2. Set correct IP

OLLAMA_URL = "http://<OLLAMA_VM_IP>:11434/api/generate"

---

## 3. Confirm model name

"model": "phi3:latest"

---

# 🧱 PART 4 — TEST PROXY (FLASK MODE)

## Run:

python3 ollama_proxy.py

---

## Test:

curl http://127.0.0.1:5000

Expected:
Proxy is running

---

## Full test:

curl http://127.0.0.1:5000/v1/chat/completions 
-H "Content-Type: application/json" 
-d '{"messages":[{"role":"user","content":"test"}]}'

---

# 🧱 PART 5 — RUN PROXY (GUNICORN MODE)

## Stop Flask if running

CTRL+C

---

## Start Gunicorn

gunicorn -w 2 -b 127.0.0.1:5000 ollama_proxy:app

---

## Test again

curl http://127.0.0.1:5000

---

# 🧱 PART 6 — MAKE PERSISTENT (SYSTEMD)

## Create service

sudo nano /etc/systemd/system/ollama-proxy.service

---

## Paste:

[Unit]
Description=Ollama Proxy Service
After=network.target

[Service]
ExecStart=/usr/bin/gunicorn -w 2 -b 127.0.0.1:5000 ollama_proxy:app
WorkingDirectory=/opt/ollama-proxy-bundle
Restart=always
User=splunk

[Install]
WantedBy=multi-user.target

---

## Enable + start

sudo systemctl daemon-reload
sudo systemctl enable ollama-proxy
sudo systemctl start ollama-proxy

---

## Verify

systemctl status ollama-proxy

---

